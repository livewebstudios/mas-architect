---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';

const mapSrc =
  'https://www.google.com/maps?q=375%20Murray%20Hill%20Pkwy,%20East%20Rutherford,%20NJ%2007073&output=embed';
---

<BaseLayout
  title="Contact | MAS Architect"
  description="Reach out to MAS Architect in East Rutherford, NJ. Call (201) 952-1500 or send us a message to start the conversation about your project."
>
  <PageHero
    eyebrow="Contact"
    title="Let’s Start the Conversation"
    intro="We’d love to hear about your project — reach out today and we’ll be in touch shortly."
  />

  <section class="section">
    <div class="container-mas grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <!-- Details -->
      <ScrollReveal>
        <div class="flex flex-col gap-8">
          <div>
            <p class="eyebrow mb-2">Our Location</p>
            <p class="text-lg text-ink/80">{site.address.line1}<br />{site.address.line2}</p>
          </div>
          <div>
            <p class="eyebrow mb-2">Phone</p>
            <a href={site.phoneHref} class="text-lg text-navy transition-colors hover:text-navy-deep" data-cursor>{site.phone}</a>
          </div>
          <div>
            <p class="eyebrow mb-2">Email</p>
            <a href={site.emailHref} class="text-lg text-navy transition-colors hover:text-navy-deep" data-cursor>{site.email}</a>
          </div>
          <div>
            <p class="eyebrow mb-3">Follow</p>
            <div class="flex gap-3">
              <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-11 w-11 items-center justify-center border border-line text-navy transition-colors hover:bg-navy hover:text-paper" data-cursor>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h3v7h3v-7h3l1-3h-4v-2c0-.6.4-1 1-1z"/></svg>
              </a>
              <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-11 w-11 items-center justify-center border border-line text-navy transition-colors hover:bg-navy hover:text-paper" data-cursor>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
            </div>
          </div>
          <div class="relative mt-2 aspect-[4/3] w-full overflow-hidden border border-line-soft">
            <iframe
              title="MAS Architect location map"
              src={mapSrc}
              class="h-full w-full"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </ScrollReveal>

      <!-- Form -->
      <ScrollReveal delay={100}>
        <div class="border border-line-soft bg-white p-7 md:p-10">
          <p class="eyebrow mb-6">Drop Us a Line</p>
          <ContactForm />
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
