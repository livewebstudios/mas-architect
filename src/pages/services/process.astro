---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import CTA from '../../components/CTA.astro';
import { process } from '../../data/services';
---

<BaseLayout
  title="Our Process | MAS Architect"
  description="From site analysis and design through variances, construction documents, bidding, and construction administration — see how MAS Architect brings every project to life."
>
  <PageHero
    eyebrow="Process"
    title="A Clear Path, Every Project"
    intro="Our process combines thoughtful design, precise planning, and expert execution. Every proposal breaks your project down into the following phases."
  />

  <section class="section">
    <div class="container-mas">
      <ol class="flex flex-col">
        {process.map((p) => (
          <ScrollReveal>
            <li class="grid gap-5 border-t border-line-soft py-9 last:border-b md:grid-cols-[7rem_1fr] md:gap-12 md:py-12">
              <span class="font-display text-5xl leading-none text-navy/25 md:text-6xl">{p.n}</span>
              <div class="flex flex-col gap-3">
                <h2 class="font-display text-2xl text-navy md:text-3xl">{p.title}</h2>
                <p class="max-w-2xl leading-relaxed text-ink/70">{p.body}</p>
              </div>
            </li>
          </ScrollReveal>
        ))}
      </ol>
    </div>
  </section>

  <CTA title="Ready to begin?" text="Let’s talk through your project and map out the right path forward." />
</BaseLayout>
