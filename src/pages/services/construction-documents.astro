---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import CTA from '../../components/CTA.astro';
import { constructionDocs } from '../../data/services';
---

<BaseLayout
  title="Construction Documents | MAS Architect"
  description="A typical set of construction documents used for bidding and permits — site plans, demolition, floor plans, elevations, electrical, sections, and specifications. Sample sheets available to download."
>
  <PageHero
    eyebrow="Construction Documents"
    title="Plans Built for Permits & Bidding"
    intro="The following is a typical set of construction documents used for bidding and permits. Every project is different, and the required information varies for each — these sample sheets show what a complete set includes."
  />

  <section class="section">
    <div class="container-mas grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {constructionDocs.map((d, i) => (
        <ScrollReveal delay={(i % 4) * 80}>
          <article class="group flex h-full flex-col border border-line-soft bg-white">
            <a href={d.pdf} target="_blank" rel="noopener noreferrer" class="relative block overflow-hidden border-b border-line-soft" data-cursor aria-label={`Open ${d.title} PDF`}>
              <img src={d.thumb} alt={`${d.title} sample sheet`} width="300" height="300" loading="lazy" decoding="async" class="aspect-square w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105" />
              <span class="absolute inset-0 flex items-center justify-center bg-navy/0 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-paper opacity-0 transition-all duration-500 group-hover:bg-navy/55 group-hover:opacity-100">View PDF</span>
            </a>
            <div class="flex flex-1 flex-col gap-2 p-6">
              <p class="eyebrow"><span class="eyebrow__num">{d.n}</span></p>
              <h2 class="font-display text-xl text-navy">{d.title}</h2>
              <p class="text-sm leading-relaxed text-ink/70">{d.body}</p>
              <a href={d.pdf} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex w-fit items-center gap-2 font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy transition-colors hover:text-navy-deep" data-cursor>
                Download PDF
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1v9m0 0L4.5 6.5M8 10l3.5-3.5M2 14h12" stroke="currentColor" stroke-width="1.3" /></svg>
              </a>
            </div>
          </article>
        </ScrollReveal>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
