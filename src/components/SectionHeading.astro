---
/**
 * Standard section header: mono eyebrow (with optional leading number)
 * + serif display title + optional intro paragraph.
 */
interface Props {
  eyebrow?: string;
  number?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, number, title, intro, align = 'left', class: className = '' } = Astro.props;
const alignCls = align === 'center' ? 'items-center text-center mx-auto' : 'items-start text-left';
---

<div class:list={['flex flex-col gap-5 max-w-3xl', alignCls, className]}>
  {eyebrow && (
    <p class="eyebrow">
      {number && <span class="eyebrow__num">{number}</span>}
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-navy text-balance">{title}</h2>
  {intro && <p class="text-ink/70 leading-relaxed md:text-lg max-w-2xl">{intro}</p>}
</div>
