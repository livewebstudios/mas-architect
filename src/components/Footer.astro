---
import DimensionLine from './blueprint/DimensionLine.astro';
const year = new Date().getFullYear();

const explore = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
const services = [
  { label: 'Process', href: '/services/process' },
  { label: 'Construction Documents', href: '/services/construction-documents' },
  { label: 'Planbooks', href: '/services/planbooks' },
  { label: 'Modular Building', href: '/services/modular-building-systems' },
];
---

<footer class="bp-grid border-t border-line-soft bg-linen">
  <div class="container-mas section !pb-10">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_auto]">
      <!-- Brand -->
      <div class="flex flex-col gap-5">
        <img src="/images/logo-trans.png" alt="MAS Architect" width="170" class="h-10 w-auto" />
        <p class="max-w-xs text-sm leading-relaxed text-ink/70">
          Rebuilding neighborhoods, one house at a time — thoughtful residential and commercial
          architecture in East Rutherford, New Jersey.
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://www.facebook.com/profile.php?id=100067624868198"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="MAS Architect on Facebook"
            class="flex h-11 w-11 items-center justify-center border border-line text-navy transition-colors hover:bg-navy hover:text-paper"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h3v7h3v-7h3l1-3h-4v-2c0-.6.4-1 1-1z"/></svg>
          </a>
          <a
            href="https://www.instagram.com/stefanelli.architect/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="MAS Architect on Instagram"
            class="flex h-11 w-11 items-center justify-center border border-line text-navy transition-colors hover:bg-navy hover:text-paper"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <!-- Explore -->
      <nav aria-label="Footer" class="flex flex-col gap-3">
        <p class="eyebrow mb-1">Explore</p>
        {explore.map((l) => (
          <a href={l.href} class="w-fit text-sm uppercase tracking-[0.12em] text-navy/80 transition-colors hover:text-navy">{l.label}</a>
        ))}
      </nav>

      <!-- Services -->
      <nav aria-label="Services" class="flex flex-col gap-3">
        <p class="eyebrow mb-1">Services</p>
        {services.map((l) => (
          <a href={l.href} class="w-fit text-sm uppercase tracking-[0.12em] text-navy/80 transition-colors hover:text-navy">{l.label}</a>
        ))}
      </nav>

      <!-- Contact -->
      <div class="flex flex-col gap-3">
        <p class="eyebrow mb-1">Contact</p>
        <address class="flex flex-col gap-3 text-sm not-italic text-ink/75">
          <span>375 Murray Hill Pkwy<br />East Rutherford, NJ 07073</span>
          <a href="tel:+12019521500" class="transition-colors hover:text-navy">(201) 952-1500</a>
          <a href="mailto:markatect2@gmail.com" class="transition-colors hover:text-navy">markatect2@gmail.com</a>
        </address>
      </div>
    </div>

    <div class="mt-14">
      <DimensionLine />
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-6 sm:flex-row">
      <p class="font-mono text-[0.72rem] uppercase tracking-[0.14em] text-indigo-muted">
        &copy; {year} MAS Architect. All rights reserved.
      </p>
      <a href="https://livewebstudios.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3" aria-label="Verified & Secured by Live Web Studios">
        <img src="/images/verifiedsecured.png" alt="Verified & Secured by Live Web Studios" width="150" height="37" />
        <span class="font-mono text-[0.66rem] uppercase tracking-[0.12em] text-indigo-muted">Powered by Live Web Studios</span>
      </a>
    </div>
  </div>
</footer>
